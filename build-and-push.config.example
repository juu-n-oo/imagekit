# build-and-push.sh 설정 파일 (예시)
#
# 사용법:
#   cp build-and-push.config.example build-and-push.config
#   # 값(특히 HARBOR_PASSWORD) 채운 뒤 실행
#   ./build-and-push.sh
#
# 이 파일은 build-and-push.sh 가 그대로 `source` 한다(셸 형식, KEY="value").
# build-and-push.config 는 비밀번호를 담으므로 git 추적 대상이 아니다(.gitignore).
# 환경변수로 미리 지정한 값이 있으면 그 값이 우선한다(설정 파일은 비어있을 때만 채운다).

# ── 레지스트리 / 이미지 경로 ─────────────────────────────────
# 최종 이미지: ${REGISTRY}/${HARBOR_PROJECT}/<name>:<tag>
# (GitHub Actions CD 의 vars.HARBOR_REGISTRY / vars.HARBOR_PROJECT 기본값과 동일)
REGISTRY="external.registry.ten1010.io"
HARBOR_PROJECT="aipub"

# ── Harbor 로그인 자격증명 ───────────────────────────────────
# 둘 다 채우면 스크립트가 자동으로 `docker login` 한다.
# 비워두면 이미 `docker login ${REGISTRY}` 된 상태로 가정한다.
# 주의: robot 계정명에 '$' 가 있으면 반드시 '작은따옴표'로 감싼다(변수 확장 방지).
HARBOR_USERNAME='robot$imagekit'
HARBOR_PASSWORD=''

# ── 빌드 플랫폼 ─────────────────────────────────────────────
# 클러스터 노드가 amd64 이므로 기본 linux/amd64.
# (Mac/arm64 에서 그냥 빌드하면 arm64 이미지가 나와 클러스터에서 안 뜬다)
PLATFORM="linux/amd64"

# ── docker 실행 커맨드 ───────────────────────────────────────
# 리눅스 노드에서 sudo 가 필요하면 "sudo docker" 로 바꾼다.
DOCKER="docker"

# ── rollout.sh 전용 설정 ─────────────────────────────────────
# 배포 대상 네임스페이스.
NAMESPACE="aipub"
# kubectl 실행 커맨드(노드에서 sudo 필요 시 "sudo kubectl").
KUBECTL="sudo kubectl"
